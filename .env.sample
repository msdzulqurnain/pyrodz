APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=info

BOT_NAME=mybot
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=123456789:ABCDEF

# --- Database (SQL) ---
# Supported drivers: sqlite, mysql, pgsql
# ==================================================
# SQLite (zero dependencies — uses stdlib sqlite3)
DB_CONNECTION=sqlite
DB_DATABASE=storage/database.sqlite

# MySQL (requires: pip install pymysql)
# DB_CONNECTION=mysql
# DB_DATABASE=pyrodz
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (requires: pip install psycopg2-binary)
# DB_CONNECTION=pgsql
# DB_DATABASE=pyrodz
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=

# --- Database (No-SQL) ---
# Supported drivers: pymongo
# ==================================================
# MongoDB (requires: pip install pymongo)
# MONGO_URI=mongodb://127.0.0.1:27017
# MONGO_DATABASE=pyrodz

